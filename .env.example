# Copy to your Railway "Variables" tab. Do NOT commit real values.

# Public URL of the main Velarion Scout app (no trailing slash).
# Use the canonical host that does NOT redirect (www) to avoid 307s.
APP_URL=https://www.velarionscout.com.br

# Shared secret — must match VIDEO_WORKER_SHARED_SECRET in the main app
WORKER_SHARED_SECRET=replace-with-strong-random-value

# Optional tuning
PORT=8080
CONCURRENCY=2
POLL_INTERVAL_MS=4000
WORKER_ID=velarion-worker-1